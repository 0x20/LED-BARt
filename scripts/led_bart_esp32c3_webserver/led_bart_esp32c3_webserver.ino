#define NUM_COLS 95
#define TEKST_LEN 19

// UART0 on GPIO20(RX)/GPIO21(TX) — dedicated to Arduino
HardwareSerial UnoSerial(0);

WebServer server(80);
WebSocketsServer ws(81);

#define LOG_MAX 4096
